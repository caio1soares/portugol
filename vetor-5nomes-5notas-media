Var
// Seção de Declarações das variáveis 
nomes: vetor [1..5] de caractere
notas: vetor [1..5] de real
contador: inteiro
media: real
soma: real
Inicio
// Média da beleza das minhas ex
//Laço para receber os valores nomes e nota de cada ex
soma<-0
para contador de 1 ate 5 faca
	escreva("Digite o nome da sua ex número: ", contador, " de 5: ")
	leia(nomes[contador])
   escreva("Digite a nota da sua ex número: ", contador, ": ")
   leia(notas[contador])
//inserir os valores do laço na variavel soma
   soma<- soma+notas[contador]
fimpara
// apresentação dos resultados, tirar media
media <- soma/contador
escreval (media)
escreval("A média da nota da beleza das suas ex é:", media)

Fimalgoritmo
